{
  "name": "downloader-api",
  "version": "1.0.0",
  "description": "API de descarga con yt-dlp",
  "license": "ISC",
  "author": "ronny",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:worker": "cd ../../ && python -m apps.worker.src.main",
    "dev:full": "concurrently \"nodemon src/server.js\" \"cd ../../ && python -m apps.worker.src.main\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "gradient-string": "^3.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
